{
    "name": "hdrm147/polygon",
    "description": "A Laravel Nova field.",
    "keywords": [
        "laravel",
        "nova"
    ],
    "license": "MIT",
    "require": {
        "php": "^8.1",
        "illuminate/support": "^10.0|^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "laravel/nova": "5.4.3",
        "laravel/nova-devtool": "^1.8"
    },
    "repositories": [
        { "type": "composer", "url": "https://nova.laravel.com" }
    ],
    "autoload": {
        "psr-4": {
            "Hdrm147\\Polygon\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Hdrm147\\Polygon\\FieldServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
